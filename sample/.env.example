# ClipsAI-JP 環境変数サンプル
#
# 使い方:
#   1. このファイルを同じディレクトリに .env としてコピー
#        cp sample/.env.example sample/.env
#   2. 各値を自分のキーに書き換える
#   3. sample/ 内のスクリプトは python-dotenv で自動的に .env を読み込む
#        pip install python-dotenv
#
# 注意: .env は秘密情報を含むため .gitignore で除外されています。
#       このサンプル (.env.example) にはダミー値のみを置き、実キーは書かないこと。

# --- Gemini API（任意）---
# ClipFinder(use_gemini=True) でクリップ検出精度を上げる場合に使用。
# 未設定でも TextTiling のみで動作します。
# 取得: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Hugging Face アクセストークン（リサイズ機能を使う場合に必要）---
# resize / Resizer は pyannote(話者分離)の学習済みモデルを利用します。
# モデルは gated のため、(1)トークン発行 と (2)モデル利用規約への同意 の両方が必要です。
#   1. トークン発行(Read権限): https://huggingface.co/settings/tokens
#   2. 規約に同意（両方）:
#        https://huggingface.co/pyannote/speaker-diarization-3.0
#        https://huggingface.co/pyannote/segmentation-3.0
# 詳細な手順は doc/SAMPLE_CODE.md「Hugging Faceトークンの取得方法」を参照。
HF_TOKEN=your_huggingface_token_here
